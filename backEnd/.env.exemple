# Server port (defaults to 3000 if not set)
PORT=3000

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/baldim

# JWT secret key
JWT_SECRET=secret

# JWT expiration time in seconds
JWT_EXPIRATION=3600

# JWT refresh token expiration time in seconds
JWT_REFRESH_EXPIRATION=1209600

# JWT refresh token usage limit
JWT_REFRESH_LIMIT=10

# JWT refresh token time to live in seconds
JWT_REFRESH_TTL=1209600