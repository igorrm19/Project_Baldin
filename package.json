{
  "name": "project_baldim",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "fox",
    "backEnd"
  ],
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p backEnd/tsconfig.json --noEmit",
    "build": "vite build",
    "build:full": "npm run typecheck && npm run build",
    "preview": "vite preview",
    "test": "jest --coverage && npm run test --workspace=backend && npm run test --workspace=fox",
    "test:ci": "jest --runInBand --coverage --coverageReporters=text --coverageReporters=lcov && npm run test:ci --workspace=backend && npm run test:ci --workspace=fox",
    "test:frontend": "jest --coverage",
    "test:backend": "npm run test --workspace=backend",
    "test:fox": "npm run test --workspace=fox",
    "lint": "eslint . --max-warnings=0",
    "lint:security": "eslint . --max-warnings=0",
    "html:validate": "html-validate -c .htmlvalidate.json 'src/**/*.html' 'fox/**/*.html'",
    "a11y": "pa11y-ci --config .pa11yci.json",
    "bundle:check": "node ./scripts/check-bundle-size.js",
    "lint:english": "cspell \"**/*\" --exclude node_modules --exclude backEnd/node_modules --exclude .git --exclude playwright-report --exclude test-results",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "autoprefixer": "^10.4.21",
    "cspell": "^9.8.0",
    "eslint": "^10.2.1",
    "eslint-plugin-no-unsanitized": "^4.0.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^50.0.0",
    "globals": "^17.5.0",
    "html-validate": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jiti": "^2.6.1",
    "pa11y-ci": "^4.1.0",
    "postcss": "^8.5.10",
    "rollup-plugin-visualizer": "^6.0.11",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
