{
  "name": "project_baldim",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "overrides": {
    "lodash": "^4.18.1"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "build:full": "npm run typecheck && npm run build",
    "preview": "vite preview",
    "test": "jest --coverage",
    "test:ci": "jest --runInBand --coverage --coverageReporters=text --coverageReporters=lcov",
    "coverage:check": "npm run test:ci",
    "coverage": "jest --coverage",
    "lint": "eslint . --max-warnings=0",
    "lint:security": "eslint . --max-warnings=0",
    "html:validate": "html-validate -c .htmlvalidate.json 'src/**/*.html' 'fox/**/*.html'",
    "a11y": "pa11y-ci --config .pa11yci.json",
    "bundle:check": "node ./scripts/check-bundle-size.js",
    "lint:english": "cspell \"**/*\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "autoprefixer": "^10.4.21",
    "cspell": "^9.8.0",
    "eslint": "^10.2.1",
    "eslint-plugin-no-unsanitized": "^4.0.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^50.0.0",
    "globals": "^17.5.0",
    "html-validate": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "jiti": "^2.6.1",
    "pa11y-ci": "^4.1.0",
    "postcss": "^8.5.10",
    "rollup-plugin-visualizer": "^6.0.11",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2"
  }
}
