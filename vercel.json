{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backEnd/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/api/?$",
      "dest": "/backEnd/api/index.ts"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/backEnd/api/index.ts"
    }
  ]
}
